# --- Database Configuration ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=database

# --- Server Configuration ---
JWT_SECRET=your_super_secret_jwt_key
PORT=5000

# URL where your frontend lives (used by the backend for CORS)
FRONTEND_URL=http://localhost:3000

# --- Email Configuration ---
# Leave SMTP_HOST empty for local development JSON email logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Edja Wallet <no-reply@example.com>"

# --- Client Configuration ---
REACT_APP_API_URL=http://localhost:5000
